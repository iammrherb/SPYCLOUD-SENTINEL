{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "value": "REPLACE-WITH-YOUR-WORKSPACE-NAME"
        },
        "createNewWorkspace": {
            "value": true
        },
        "spycloudApiKey": {
            "value": "REPLACE-WITH-YOUR-SPYCLOUD-API-KEY"
        },
        "spycloudApiRegion": {
            "value": "us"
        },
        "deploymentRegion": {
            "value": "eastus"
        },
        "enableKeyVault": {
            "value": true
        },
        "enableMdePlaybook": {
            "value": true
        },
        "enableCaPlaybook": {
            "value": true
        },
        "enableAnalyticsRule": {
            "value": true
        },
        "enableAutomationRule": {
            "value": true
        },
        "enableAnalyticsRulesLibrary": {
            "value": false
        },
        "enableNotifications": {
            "value": false
        },
        "retentionInDays": {
            "value": 90
        }
    }
}
