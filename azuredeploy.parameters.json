{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "value": "REPLACE-WITH-YOUR-WORKSPACE-NAME"
        },
        "createNewWorkspace": {
            "value": true
        },
        "spycloudApiKey": {
            "value": "REPLACE-WITH-YOUR-SPYCLOUD-API-KEY"
        },
        "spycloudApiRegion": {
            "value": "us"
        },
        "deploymentRegion": {
            "value": "eastus"
        },
        "enableKeyVault": {
            "value": true
        },
        "enableMdePlaybook": {
            "value": true
        },
        "enableCaPlaybook": {
            "value": true
        },
        "enableAnalyticsRule": {
            "value": true
        },
        "enableAutomationRule": {
            "value": true
        },
        "enableAnalyticsRulesLibrary": {
            "value": false
        },
        "enableSessionCookieDetection": {
            "value": false
        },
        "enableIdentityProviderAlerts": {
            "value": false
        },
        "enableNotifications": {
            "value": false
        },
        "notificationEmail": {
            "value": ""
        },
        "severityFilter": {
            "value": ["2", "5", "20", "25"]
        },
        "watchlistType": {
            "value": ["corporate", "infected", "compass"]
        },
        "showPlainPassword": {
            "value": "False"
        },
        "queryWindowInMin": {
            "value": 40
        },
        "rateLimitQPS": {
            "value": 2
        },
        "retentionInDays": {
            "value": 90
        },
        "initialLookbackDays": {
            "value": 30
        }
    }
}
