{
  "name": "spycloud-sentinel-solution",
  "version": "2.0.0",
  "description": "SpyCloud Identity Threat Protection for Microsoft Sentinel",
  "author": "SpyCloud, Inc.",
  "license": "MIT",
  "homepage": "https://spycloud.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/iammrherb/SPYCLOUD-SENTINEL"
  },
  "keywords": [
    "spycloud",
    "microsoft-sentinel",
    "azure",
    "siem",
    "soar",
    "threat-intelligence",
    "darknet",
    "identity-protection",
    "infostealer",
    "breach-detection",
    "security-copilot"
  ],
  "files": [
    "azuredeploy.json",
    "createUiDefinition.json",
    "mainTemplate.json",
    "solutionMetadata.json",
    "playbooks/**/*.json",
    "templates/**/*.json",
    "workbooks/**/*.json",
    "analytics-rules/**/*.yaml",
    "hunting-queries.json",
    "copilot/**/*",
    "scripts/**/*",
    "docs/**/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "validate": "node scripts/validate-templates.js",
    "package": "node scripts/package-solution.js",
    "test": "node scripts/run-tests.js",
    "deploy:staging": "az deployment group create --resource-group $STAGING_RG --template-file azuredeploy.json --parameters @azuredeploy.parameters.json",
    "deploy:production": "az deployment group create --resource-group $PRODUCTION_RG --template-file azuredeploy.json --parameters @azuredeploy.parameters.json"
  },
  "devDependencies": {
    "@azure/arm-resources": "^5.0.0",
    "@azure/identity": "^4.0.0"
  }
}
