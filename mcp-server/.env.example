# SpyCloud MCP Server — Environment Configuration
# Copy to .env and fill in your values

# Required — SpyCloud Enterprise API Key
SPYCLOUD_API_KEY=your-enterprise-api-key-from-portal.spycloud.com

# Optional — Server port (default: 3001)
PORT=3001

# Optional — API region: us (default) or eu
SPYCLOUD_API_REGION=us

# Optional — Product-specific API keys (if different from enterprise key)
SPYCLOUD_INVESTIGATIONS_KEY=
SPYCLOUD_SIP_KEY=
SPYCLOUD_IDLINK_KEY=
SPYCLOUD_CAP_KEY=

# Optional — Azure Sentinel (for future KQL integration)
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
SENTINEL_WORKSPACE=
