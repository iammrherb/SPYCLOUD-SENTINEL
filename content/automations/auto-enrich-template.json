{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "templateMetadata": {
    "templateVersion": "1.0.0",
    "templateId": "spycloud-auto-enrich",
    "category": "Automation",
    "requiredPermissions": [
      "Microsoft.OperationalInsights/workspaces/read",
      "Microsoft.SecurityInsights/automationRules/write",
      "Microsoft.Logic/workflows/read"
    ],
    "requiredLicenses": [
      "Microsoft Sentinel",
      "SpyCloud Enterprise API"
    ],
    "connectorAssociation": [
      "azuresentinel"
    ],
    "deployAsTemplate": true
  },
  "metadata": {
    "_generator": { "name": "SpyCloud Sentinel Integration", "version": "1.0.0" },
    "title": "SpyCloud - Auto-Enrich with SpyCloud Data",
    "description": "Automatically enriches all SpyCloud-related incidents with breach data from the SpyCloud Enterprise API. Runs the EnrichIncident and ExposureAssessment playbooks on incident creation to add severity scores, breach details, and risk assessment.",
    "prerequisites": [
      "Microsoft Sentinel workspace",
      "SpyCloud-EnrichIncident playbook deployed",
      "SpyCloud-ExposureAssessment playbook deployed (optional)"
    ],
    "lastUpdateTime": "2026-03-11T00:00:00.000Z",
    "support": { "tier": "community" },
    "author": { "name": "SpyCloud" }
  },
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": { "description": "Microsoft Sentinel workspace name" }
    },
    "subscriptionId": {
      "type": "string",
      "metadata": { "description": "Azure Subscription ID" }
    },
    "resourceGroupName": {
      "type": "string",
      "metadata": { "description": "Resource group for this deployment" }
    },
    "enrichIncidentPlaybookId": {
      "type": "string",
      "metadata": { "description": "Resource ID of the SpyCloud-EnrichIncident Logic App" }
    },
    "exposureAssessmentPlaybookId": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Resource ID of the SpyCloud-ExposureAssessment Logic App (optional, leave empty to skip)" }
    },
    "enableForAllIncidents": {
      "type": "bool",
      "defaultValue": false,
      "metadata": { "description": "Enable enrichment for all incidents (true) or only SpyCloud-related incidents (false)" }
    }
  },
  "variables": {
    "workspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspaceName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.SecurityInsights/automationRules",
      "apiVersion": "2023-02-01",
      "name": "spycloud-auto-enrich-incident",
      "scope": "[variables('workspaceResourceId')]",
      "properties": {
        "displayName": "SpyCloud Auto-Enrich: Breach Data Enrichment",
        "order": 5,
        "triggeringLogic": {
          "isEnabled": true,
          "triggersOn": "Incidents",
          "triggersWhen": "Created",
          "conditions": "[if(parameters('enableForAllIncidents'), json('[]'), json('[{\"conditionType\":\"Property\",\"conditionProperties\":{\"propertyName\":\"IncidentProviderName\",\"operator\":\"Contains\",\"propertyValues\":[\"SpyCloud\"]}}]'))]"
        },
        "actions": [
          {
            "actionType": "RunPlaybook",
            "order": 1,
            "actionConfiguration": {
              "logicAppResourceId": "[parameters('enrichIncidentPlaybookId')]",
              "tenantId": "[subscription().tenantId]"
            }
          },
          {
            "actionType": "ModifyProperties",
            "order": 2,
            "actionConfiguration": {
              "labels": [
                { "labelName": "Auto-Enrichment-Triggered" }
              ]
            }
          }
        ]
      }
    },
    {
      "condition": "[not(empty(parameters('exposureAssessmentPlaybookId')))]",
      "type": "Microsoft.SecurityInsights/automationRules",
      "apiVersion": "2023-02-01",
      "name": "spycloud-auto-enrich-exposure",
      "scope": "[variables('workspaceResourceId')]",
      "properties": {
        "displayName": "SpyCloud Auto-Enrich: Exposure Risk Assessment",
        "order": 6,
        "triggeringLogic": {
          "isEnabled": true,
          "triggersOn": "Incidents",
          "triggersWhen": "Created",
          "conditions": [
            {
              "conditionType": "Property",
              "conditionProperties": {
                "propertyName": "IncidentProviderName",
                "operator": "Contains",
                "propertyValues": ["SpyCloud"]
              }
            },
            {
              "conditionType": "Property",
              "conditionProperties": {
                "propertyName": "IncidentSeverity",
                "operator": "Equals",
                "propertyValues": ["High", "Medium"]
              }
            }
          ]
        },
        "actions": [
          {
            "actionType": "RunPlaybook",
            "order": 1,
            "actionConfiguration": {
              "logicAppResourceId": "[parameters('exposureAssessmentPlaybookId')]",
              "tenantId": "[subscription().tenantId]"
            }
          },
          {
            "actionType": "ModifyProperties",
            "order": 2,
            "actionConfiguration": {
              "labels": [
                { "labelName": "Exposure-Assessment-Triggered" }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "enrichmentRuleId": {
      "type": "string",
      "value": "[resourceId('Microsoft.SecurityInsights/automationRules', 'spycloud-auto-enrich-incident')]"
    }
  }
}
